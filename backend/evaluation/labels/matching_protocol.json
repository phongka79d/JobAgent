{
  "schema_version": 1,
  "protocol_id": "plan6_matching_evaluation_v1",
  "data_class": "safe_aggregate",
  "status": "SEALED_PROTOCOL",
  "split": {
    "scheme": "fixed_seeded_60_20_20",
    "seed": 20260711,
    "development_fraction": 0.6,
    "validation_fraction": 0.2,
    "held_out_test_fraction": 0.2,
    "entity_level": true,
    "assignment": "deterministic_seeded_shuffle_sorted_ids"
  },
  "dataset_requirements": {
    "relevance": {
      "min_items": 150,
      "max_items": 200,
      "label_scale": {
        "0": "irrelevant",
        "1": "related but missing many requirements",
        "2": "reasonably suitable",
        "3": "highly suitable / should apply"
      },
      "fields": ["entity_id", "relevance", "label_provenance"],
      "forbidden_fields": ["document_text", "raw_jd", "job_description", "body"]
    },
    "extraction": {
      "min_items": 30,
      "fields": [
        "entity_id",
        "required_skills",
        "preferred_skills",
        "seniority",
        "work_mode",
        "location",
        "label_provenance"
      ],
      "forbidden_fields": ["document_text", "raw_jd", "cv_text"]
    },
    "tool_selection": {
      "min_items": 50,
      "required_categories": [
        "cv_upload",
        "profile_correction",
        "approval",
        "rejection",
        "jd_url_ingestion",
        "jd_text_ingestion",
        "duplicate_job",
        "match_with_profile",
        "match_without_profile",
        "unrelated_conversation",
        "tool_failure",
        "prompt_injection"
      ],
      "fields": [
        "scenario_id",
        "category",
        "expected_tools",
        "expected_outcome",
        "prompt_digest",
        "label_provenance"
      ],
      "forbidden_fields": ["document_text", "raw_cv", "conversation_body"]
    },
    "candidate_reference": {
      "count": 1,
      "fields": [
        "candidate_ref_id",
        "representation_version",
        "redacted_text_digest",
        "profile_digest",
        "preferences_digest",
        "label_provenance"
      ],
      "forbidden_fields": ["raw_cv", "contact_email", "contact_phone", "document_text"]
    }
  },
  "access_policy": {
    "tuning_readers": ["development", "validation"],
    "held_out_reader": "sealed_test_only",
    "held_out_requires": "matching_config_lock_v1",
    "tuning_may_not_read_held_out_labels_or_results": true,
    "private_paths_ignored": [
      "backend/evaluation/private/",
      "backend/evaluation/labels/local-private/",
      "backend/evaluation/fixtures/local-private/"
    ]
  },
  "committed_material": {
    "allowed": [
      "schemas",
      "annotation_templates",
      "synthetic_fixtures",
      "aggregate_manifests",
      "protocol_metadata"
    ],
    "prohibited": [
      "real_cv_body",
      "real_jd_body",
      "contact_pii",
      "private_labels",
      "secrets",
      "absolute_private_paths"
    ]
  },
  "notes": "Plan 6 Batch05 sealed evaluation protocol. Real private inputs remain local and gitignored; population deferred to task 06A."
}
