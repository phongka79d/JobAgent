# Docker build context is the repository root for frontend/backend images.
# Keep contexts clean: never send secrets, private corpora, or heavy local junk.

# Secrets and local env (root contract is injected by Compose at runtime)
.env
.env.*
!.env.example
**/.env
**/.env.*

# VCS and editor
.git
.gitignore
.gitattributes
.github
.vscode
.idea
.agent
**/.DS_Store
Thumbs.db

# Docs and task orchestration (not required to build app images)
docs
*.md
!frontend/AGENTS.md

# Python caches and virtualenvs
**/__pycache__
**/*.py[cod]
**/*$py.class
**/.pytest_cache
**/.mypy_cache
**/.ruff_cache
**/.coverage
**/htmlcov
**/.tox
**/.venv
**/venv
**/env
**/*.egg-info
**/dist
**/build
backend/.venv
backend/runtime
backend/uploads

# Private / local evaluation inputs (must never enter an image)
backend/evaluation/private
backend/evaluation/fixtures/local-private
backend/evaluation/labels/local-private
backend/evaluation/reports

# Frontend install and build artifacts (image rebuilds them)
frontend/node_modules
frontend/dist
frontend/coverage

# Local data mounts (named volumes own runtime data)
data
/data

# Nested docker noise
**/.docker
**/docker-compose.override.yml
